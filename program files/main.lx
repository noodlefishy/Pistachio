main:
    movi r6 stack

	movi r1 string

	.loop:


	movi r1 0x0001
    movi r2 0xFF03
    sw r1 [r2 + #0]        // Intisilaises the window

    movi r1 0xFF0F    // Loads the base address for the window
    addi r1 r1 #27     // Makes it (4,4) (3 * 8 + 3)
    movi r2 0x07E0    // Green
    sw r2 [r1 + 0]        // add to window


	halt


s1: .fill "Hello"
s2: .fill "Hello"

.space 20
stack:




